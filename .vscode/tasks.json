{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "power_on",
      "command": "JLinkExe -CommandFile .vscode/jlink/power-on.jlink",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "power_off",
      "command": "JLinkExe -CommandFile .vscode/jlink/power-off.jlink",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "build_bootloader",
      "options": {
        "cwd": "bootloader"
      },
      "command": "make bin",
      "problemMatcher": "$gcc"
    },
    {
      "type": "shell",
      "label": "build_debug",
      "options": {
        "cwd": "app"
      },
      "command": "make bin",
      "problemMatcher": "$gcc"
    },
    {
      "label": "pad_bootloader",
      "type": "shell",
      "command": "C:/msys64/usr/bin/python3.exe bootloaderPadding.py",
      "options": {
        "cwd": "${workspaceFolder}/bootloader"
      }
    },
    {
      "label": "build_libopencm3",
      "type": "shell",
      "command": "$env:PATH = 'C:\\msys64\\usr\\bin;' + $env:PATH; make",
      "options": {
        "cwd": "${workspaceFolder}/libopencm3"
      },
      "problemMatcher": "$gcc"
    }
  ]
}